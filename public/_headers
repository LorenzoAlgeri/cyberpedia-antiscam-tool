/*
 * Cloudflare Pages custom headers
 * Applied automatically at the edge — no server needed.
 *
 * Security headers per /security-requirement-extraction:
 * - CSP frame-ancestors for iframe integration with cyberpedia.it
 * - Full browser-side hardening (XSS, clickjacking, MIME sniffing)
 * - Strict CSP for inline scripts: only vite-generated hashes
 */

/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://antiscam-worker.lorenzo-algeri.workers.dev; frame-ancestors 'self' https://cyberpedia.it https://*.cyberpedia.it; base-uri 'self'; form-action 'self'; object-src 'none'; worker-src 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Service worker must be served without caching for updates to work
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets: immutable cache (filenames have content hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
