/*
 * Cloudflare Pages custom headers
 * Applied automatically at the edge — no server needed.
 *
 * Security headers for iframe integration with cyberpedia.it
 * and general hardening.
 */

/*
  Content-Security-Policy: frame-ancestors 'self' https://cyberpedia.it https://*.cyberpedia.it
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
